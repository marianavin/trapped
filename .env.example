# Copy this file to .env and fill in your Supabase project's values.
# Without these, the app runs in local dev-mode (nickname login,
# progress saved to localStorage only) — see SUPABASE_SETUP.md.

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Restricts Google sign-in to a single Workspace domain, e.g. vinted.com
VITE_ALLOWED_EMAIL_DOMAIN=
